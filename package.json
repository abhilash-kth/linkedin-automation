{
  "name": "linkedin-automation",
  "version": "2.0.0",
  "description": "AI-powered LinkedIn outreach automation",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "scheduler": "node scripts/pc-scheduler.js",
    "scheduler:pm2": "pm2 start ecosystem.config.js",
    "login": "node scripts/run-login.js",
    "manual-login": "node scripts/run-manual-login.js",
    "outreach": "node scripts/run-single.js",
    "batch": "node scripts/run-batch.js",
    "send": "node scripts/run-batch.js account_1 data/leads.json --send",
    "monitor": "node scripts/run-inbox-monitor.js",
    "ai-reply": "node scripts/run-ai-replies.js",
    "check-acceptance": "node scripts/run-acceptance-check.js account_1",
    "warming": "node scripts/run-warming.js account_1 --send",
    "sync-sheet": "node scripts/run-sheet-sync.js",
    "gh:score": "node scripts/gh-ai-scoring.js",
    "gh:analyze": "node scripts/gh-ai-analysis.js",
    "gh:sync": "node scripts/gh-sheet-sync.js",
    "gh:report": "node scripts/gh-daily-report.js",
    "gh:backup": "node scripts/gh-mongo-backup.js",
    "debug-buttons": "node debug/capture-buttons.js",
    "debug-message": "node debug/debug-message.js",
    "embed-keywords": "node scripts/embed-keywords.js",
    "discover:real": "node scripts/run-discovery.js account_2 --comment",
    "embed-requirements": "node scripts/embed-requirements.js",
    "embed-all": "npm run embed-keywords && npm run embed-requirements",
    "comment-replies": "node scripts/run-comment-replies.js account_1",
    "comment-replies:real": "node scripts/run-comment-replies.js account_2 --send"
  },
  "keywords": ["linkedin", "automation", "ai"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.1.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^173.0.0",
    "mongoose": "^9.7.4",
    "node-cron": "^4.6.0",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
